<TEI xmlns="http://www.tei-c.org/ns/1.0" xmlns:sch="http://purl.oclc.org/dsdl/schematron" xml:lang="de">
  <teiHeader>
    <fileDesc>
      <titleStmt>
        <title>KRP-Schema</title>
        <author>Timo Frühwirth</author>
      </titleStmt>
      <publicationStmt>
        <publisher key="https://d-nb.info/gnd/1001454-8">Österreichische Akademie der Wissenschaften</publisher>
