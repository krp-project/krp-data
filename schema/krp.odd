        <p>Basierend auf "TEI Complete"-Customization.</p>
      </sourceDesc>
    </fileDesc>
    <encodingDesc>
      <appInfo>
        <application ident="RomaJS" version="1.3.2" when="2026-04-28T08:17:08.622Z">
          <desc>Datei mit <ref target="https://github.com/TEIC/romajs">RomaJS</ref> erstellt.</desc>
